{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "projectName",
            "type": "promptString",
            "description": "Project name  (e.g. Acme Corp - API Modernization Phase 1)"
        },
        {
            "id": "projectDescription",
            "type": "promptString",
            "description": "One-sentence description of what this project delivers"
        },
        {
            "id": "problemStatement",
            "type": "promptString",
            "description": "Problem being solved \u2014 current state and desired outcome"
        },
        {
            "id": "isIR",
            "type": "pickString",
            "description": "Is this an IR or security engineering engagement?",
            "options": [
                "yes",
                "no"
            ],
            "default": "no"
        },
        {
            "id": "language",
            "type": "pickString",
            "description": "Primary scripting language(s) for this project",
            "options": [
                "python",
                "powershell",
                "both"
            ],
            "default": "python"
        }
    ],
    "tasks": [
        {
            "label": "Initialize Copilot Workspace",
            "detail": "Writes project context to copilot-instructions.md, toggles IR and language sections, and commits",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/init-copilot.ps1",
                "-ProjectName",
                {
                    "value": "${input:projectName}",
                    "quoting": "strong"
                },
                "-Description",
                {
                    "value": "${input:projectDescription}",
                    "quoting": "strong"
                },
                "-ProblemStatement",
                {
                    "value": "${input:problemStatement}",
                    "quoting": "strong"
                },
                "-IsIR",
                "${input:isIR}",
                "-Language",
                "${input:language}"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "runOptions": {
                "runOn": "default"
            }
        }
    ]
}
