{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Initialize Copilot Workspace",
            "detail": "Prompts for project context in the terminal, writes copilot-instructions.md and commits",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/init-copilot.ps1"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "runOptions": {
                "runOn": "default"
            }
        }
    ]
}
